# flutter-multi-payment-platform — Environment Config
# Copy to .env — NEVER commit real values

# API
DEV_BASE_URL=https://dev-api.paymentplatform.com/v1
QA_BASE_URL=https://qa-api.paymentplatform.com/v1
UAT_BASE_URL=https://uat-api.paymentplatform.com/v1
PROD_BASE_URL=https://api.paymentplatform.com/v1

# Razorpay
RAZORPAY_KEY_ID_TEST=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET_TEST=YOUR_KEY_SECRET
RAZORPAY_KEY_ID_LIVE=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET_LIVE=YOUR_LIVE_SECRET

# Stripe
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_YOUR_STRIPE_KEY
STRIPE_SECRET_KEY_TEST=sk_test_YOUR_STRIPE_SECRET
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_YOUR_STRIPE_KEY
STRIPE_SECRET_KEY_LIVE=sk_live_YOUR_STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# PayPal
PAYPAL_CLIENT_ID_SANDBOX=YOUR_PAYPAL_SANDBOX_CLIENT_ID
PAYPAL_SECRET_SANDBOX=YOUR_PAYPAL_SANDBOX_SECRET
PAYPAL_CLIENT_ID_LIVE=YOUR_PAYPAL_LIVE_CLIENT_ID
PAYPAL_SECRET_LIVE=YOUR_PAYPAL_LIVE_SECRET

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# Encryption
PAYMENT_TOKEN_ENCRYPTION_KEY=your-32-byte-key-in-base64==

# Android Signing
ANDROID_KEYSTORE_BASE64=your-keystore-base64
ANDROID_KEY_ALIAS=your-key-alias
ANDROID_KEY_PASSWORD=your-key-password
ANDROID_STORE_PASSWORD=your-store-password

# iOS Signing
IOS_P12_BASE64=your-p12-base64
IOS_P12_PASSWORD=your-password
APPLE_TEAM_ID=YOUR_TEAM_ID
